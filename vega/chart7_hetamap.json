{
  "$schema": "https://vega.github.io/schema/vega-lite/v6.json",
  "title": {
    "text": "Healthcare Workforce Composition by State (2022)",
    "fontSize": 14,
    "font": "sans-serif",
    "color": "#111111",
    "fontWeight": "bold",
    "anchor": "start",
    "subtitle": "Share of each staff type as % of total state workforce",
    "subtitleFontSize": 11,
    "subtitleColor": "#555555",
    "subtitlePadding": 4
  },
  "width": 280,
  "height": 400,
  "data": {
    "url": "https://raw.githubusercontent.com/NandhiniHar/FIT2179-DV2/refs/heads/main/data/healthcare_staff.csv"
  },
  "transform": [
    { "filter": "year(toDate(datum.date)) == 2022" },
    { "filter": "datum.type != 'all'" },
    { "filter": "datum.state != 'Malaysia'" },
    {
      "calculate": "datum.type == 'nurse_community' ? 'Community Nurse' : datum.type == 'nurse' ? 'Nurse' : datum.type == 'doctor' ? 'Doctor' : 'Dentist'",
      "as": "staff_label"
    },
    {
      "calculate": "datum.type == 'doctor' ? 1 : datum.type == 'nurse' ? 2 : datum.type == 'nurse_community' ? 3 : 4",
      "as": "sort_order"
    },
    {
      "joinaggregate": [{ "op": "sum", "field": "staff", "as": "total_per_state" }],
      "groupby": ["state"]
    },
    {
      "calculate": "datum.staff / datum.total_per_state * 100",
      "as": "pct"
    }
  ],
  "mark": {
    "type": "rect",
    "stroke": "white",
    "strokeWidth": 1
  },
  "encoding": {
    "x": {
      "field": "staff_label",
      "type": "nominal",
      "title": null,
      "sort": { "field": "sort_order", "op": "min", "order": "ascending" },
      "axis": {
        "labelAngle": 0,
        "labelFontSize": 11,
        "labelLineHeight": 15,
        "orient": "bottom",
        "ticks": false,
        "domain": false,
        "labelExpr": "datum.label === 'Community Nurse' ? ['Community', 'Nurse'] : datum.label"
      }
    },
    "y": {
      "field": "state",
      "type": "nominal",
      "title": null,
      "sort": {
        "field": "staff",
        "op": "sum",
        "order": "descending"
      },
      "axis": {
        "labelFontSize": 11,
        "ticks": false,
        "domain": false
      }
    },
    "color": {
      "field": "pct",
      "type": "quantitative",
      "title": "% of State Workforce",
      "scale": {
        "scheme": "blues",
        "domain": [0, 70]
      },
      "legend": {
        "orient": "bottom",
        "direction": "horizontal",
        "titleFontSize": 10,
        "labelFontSize": 9,
        "gradientLength": 220,
        "gradientThickness": 10,
        "format": ".0f",
        "labelExpr": "datum.label + '%'"
      }
    },
    "tooltip": [
      { "field": "state", "type": "nominal", "title": "State" },
      { "field": "staff_label", "type": "nominal", "title": "Staff Type" },
      { "field": "staff", "type": "quantitative", "title": "Count", "format": "," },
      { "field": "pct", "type": "quantitative", "title": "% of State", "format": ".1f" }
    ]
  },
  "config": {
    "view": { "stroke": null },
    "axis": { "grid": false }
  }
}
