{
  "$schema": "https://vega.github.io/schema/vega-lite/v6.json",
  "title": {
    "text": "MOH Hospitals Dominate Bed Provision Across All States (2022)",
    "fontSize": 20,
    "font": "sans-serif",
    "color": "#111111",
    "fontWeight": "bold",
    "anchor": "start",
    "subtitle": "Share of public hospital beds by hospital type - each bar sums to 100%",
    "subtitleFontSize": 13,
    "subtitleColor": "#555555",
    "subtitlePadding": 4
  },
  "width": 500,
  "height": 400,
  "data": {
    "url": "https://raw.githubusercontent.com/NandhiniHar/FIT2179-DV2/refs/heads/main/data/hospital_beds.csv"
  },
  "transform": [
    { "filter": "year(toDate(datum.date)) == 2022" },
    { "filter": "datum.state != 'Malaysia'" },
    { "filter": "datum.district == 'All Districts'" },
    { "filter": "datum.type != 'all'" },
    {
      "calculate": "datum.type == 'hospital_moh' ? 'MOH Hospital' : datum.type == 'hospital_non_moh' ? 'Non-MOH Hospital' : 'Special Medical Inst.'",
      "as": "type_label"
    },
    {
      "calculate": "datum.type == 'hospital_moh' ? 1 : datum.type == 'hospital_non_moh' ? 2 : 3",
      "as": "sort_order"
    }
  ],
  "mark": { "type": "bar" },
  "encoding": {
    "x": {
      "field": "beds",
      "type": "quantitative",
      "title": "Share of Hospital Beds (%)",
      "stack": "normalize",
      "axis": {
        "format": "%",
        "labelAngle": 0,
        "ticks": false,
        "domain": false,
        "gridColor": "#e0e0e0",
        "gridDash": [3, 3]
      }
    },
    "y": {
      "field": "state",
      "type": "nominal",
      "title": null,
      "sort": { "field": "beds", "op": "sum", "order": "descending" },
      "axis": {
        "labelFontSize": 11,
        "ticks": false,
        "domain": false
      }
    },
    "color": {
      "field": "type_label",
      "type": "nominal",
      "title": "Hospital Type",
      "sort": { "field": "sort_order", "op": "min" },
      "scale": {
        "domain": ["MOH Hospital", "Non-MOH Hospital", "Special Medical Inst."],
        "range": ["#1a5c42", "#74b8a0", "#c8e6d0"]
      },
      "legend": {
        "orient": "bottom",
        "direction": "horizontal",
        "titleFontSize": 10,
        "labelFontSize": 10,
        "columnPadding": 12,
        "padding": 6
      }
    },
    "order": {
      "field": "sort_order",
      "type": "quantitative"
    },
    "tooltip": [
      { "field": "state", "type": "nominal", "title": "State" },
      { "field": "type_label", "type": "nominal", "title": "Hospital Type" },
      { "field": "beds", "type": "quantitative", "title": "Beds", "format": "," }
    ]
  },
  "config": {
    "view": { "stroke": null },
    "axis": { "grid": false }
  }
}